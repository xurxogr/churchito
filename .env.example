# Discord Bot Configuration
# Copy this file to .env and fill in your values

# Bot Settings
BOT__TOKEN=your_discord_bot_token_here
BOT__COMMAND_PREFIX=!
BOT__OWNER_ID=
BOT__DESCRIPTION=Un bot de Discord con arquitectura basada en cogs
# Event loop monitoring threshold in seconds (warns if operations take longer)
BOT__EVENT_LOOP_WARNING_THRESHOLD=0.5

# Database Settings
DATABASE__URL=sqlite+aiosqlite:///data/bot.db

# Logging Settings
LOGGING__LOG_LEVEL=INFO
LOGGING__LOG_FILE=
# Rotate log files daily at midnight (requires LOGGING__LOG_FILE to be set)
LOGGING__ROTATE_LOGS=false
LOGGING__LOG_FORMAT=[%(asctime)s] %(levelname)s [%(name)s] %(message)s
LOGGING__DATE_FORMAT=%Y-%m-%d %H:%M:%S

# Web Dashboard Settings
WEB__ENABLED=false
WEB__HOST=0.0.0.0
WEB__PORT=8000
# Secret key for sessions (generate a strong random string)
WEB__SECRET_KEY=
# Discord OAuth Application credentials (from Discord Developer Portal)
WEB__CLIENT_ID=
WEB__CLIENT_SECRET=
WEB__REDIRECT_URI=http://localhost:8000/auth/callback
# User IDs with admin access to the dashboard (comma-separated for multiple)
WEB__OWNER_IDS=[]
