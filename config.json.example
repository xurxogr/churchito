{
  "bot": {
    "token": "YOUR_DISCORD_BOT_TOKEN",
    "command_prefix": "!",
    "owner_id": null,
    "description": "Un bot de Discord con arquitectura basada en cogs",
    "event_loop_warning_threshold": 0.5
  },
  "database": {
    "url": "postgresql+asyncpg://discord:YOUR_PASSWORD@db:5432/discord",
    "echo": false,
    "pool_recycle": 3600
  },
  "logging": {
    "log_level": "INFO",
    "log_format": "[%(asctime)s] %(levelname)s [%(name)s] %(message)s",
    "date_format": "%Y-%m-%d %H:%M:%S",
    "rotate_logs": false,
    "log_file": null
  },
  "web": {
    "enabled": true,
    "host": "0.0.0.0",
    "port": 8000,
    "secret_key": "GENERATE_A_RANDOM_SECRET_KEY",
    "client_id": "YOUR_DISCORD_OAUTH_CLIENT_ID",
    "client_secret": "YOUR_DISCORD_OAUTH_CLIENT_SECRET",
    "redirect_uri": "https://your-domain.com/auth/callback",
    "owner_ids": []
  }
}
